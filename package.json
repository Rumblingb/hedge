{
  "name": "rumbling-hedge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Guarded demo-first futures trading lab for Topstep-style paper trading, research, and offline evolution.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "context-drift": "powershell -ExecutionPolicy Bypass -File scripts/context-drift.ps1",
    "worktrees": "powershell -ExecutionPolicy Bypass -File scripts/worktree-init.ps1",
    "sim": "tsx src/cli.ts sim",
    "backtest": "tsx src/cli.ts backtest",
    "research": "tsx src/cli.ts research",
    "day-plan": "tsx src/cli.ts day-plan",
    "dashboard": "tsx src/cli.ts dashboard",
    "kill-switch": "tsx src/cli.ts kill-switch",
    "fetch-free": "tsx src/cli.ts fetch-free",
    "fetch-free-universe": "tsx src/cli.ts fetch-free-universe",
    "data-quality": "tsx src/cli.ts data-quality",
    "normalize-universe": "tsx src/cli.ts normalize-universe",
    "oos-rolling": "tsx src/cli.ts oos-rolling",
    "live-readiness": "tsx src/cli.ts live-readiness",
    "demo-tomorrow": "tsx src/cli.ts demo-tomorrow",
    "risk-model": "tsx src/cli.ts risk-model",
    "jarvis": "tsx src/cli.ts jarvis",
    "jarvis-loop": "tsx src/cli.ts jarvis-loop",
    "jarvis-brief": "tsx src/cli.ts jarvis-brief",
    "inspect-csv": "tsx src/cli.ts inspect-csv",
    "evolve": "tsx src/cli.ts evolve",
    "doctor": "tsx src/cli.ts doctor"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "luxon": "^3.7.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
