#!/bin/bash
set -euo pipefail
source "$(dirname -- "$0")/_bill-common.sh"

command_name="${1:-status}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command_name" in
  status)
    run_bill_cli openjarvis-status "$@"
    ;;
  approve)
    run_bill_cli hermes-supervisor-approve "$@"
    ;;
  pause)
    run_bill_cli hermes-supervisor-pause "$@"
    ;;
  resume)
    run_bill_cli hermes-supervisor-resume "$@"
    ;;
  complete)
    run_bill_cli hermes-supervisor-complete "$@"
    ;;
  why)
    run_bill_cli hermes-supervisor-why "$@"
    ;;
  bill)
    if [[ $# -eq 0 ]]; then
      echo "Usage: openjarvis bill <bill-cli-command> [args...]" >&2
      exit 2
    fi
    run_bill_cli "$@"
    ;;
  jarvis-brief)
    run_bill_cli jarvis-brief "$@"
    ;;
  opportunity)
    run_bill_cli opportunity-snapshot "$@"
    ;;
  *)
    echo "Usage: openjarvis [status|approve <taskId> [note]|pause <taskId> [note]|resume <taskId> [note]|complete <taskId> [note]|why <taskId>|bill <command...>|jarvis-brief [args...]|opportunity]" >&2
    exit 2
    ;;
esac
