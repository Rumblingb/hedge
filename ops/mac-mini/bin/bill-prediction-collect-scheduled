#!/bin/bash
set -euo pipefail
source "$(dirname -- "$0")/_bill-common.sh"
load_bill_env
if [[ "${BILL_ENABLE_PREDICTION_COLLECT:-false}" != "true" ]]; then
  printf '{\n  "command": "bill-prediction-collect-scheduled",\n  "status": "skipped",\n  "reason": "BILL_ENABLE_PREDICTION_COLLECT is not true"\n}\n'
  exit 0
fi
source_name="${BILL_PREDICTION_SOURCE:-polymarket}"
limit="${BILL_PREDICTION_COLLECT_LIMIT:-25}"
out_path="${BILL_PREDICTION_COLLECT_OUTPUT_PATH:-.rumbling-hedge/runtime/prediction/${source_name}-live-snapshot.json}"
run_bill_cli prediction-collect "$source_name" "$limit" "$out_path"
