#!/bin/bash
set -euo pipefail
source "$(dirname -- "$0")/_bill-common.sh"
load_bill_env
if [[ "${BILL_ENABLE_PREDICTION_SCAN:-false}" != "true" ]]; then
  printf '{\n  "command": "bill-prediction-scan-scheduled",\n  "status": "skipped",\n  "reason": "BILL_ENABLE_PREDICTION_SCAN is not true"\n}\n'
  exit 0
fi
snapshot_path="${BILL_PREDICTION_SNAPSHOT_PATH:-}"
if [[ -z "$snapshot_path" ]]; then
  printf '{\n  "command": "bill-prediction-scan-scheduled",\n  "status": "skipped",\n  "reason": "BILL_PREDICTION_SNAPSHOT_PATH is not set"\n}\n'
  exit 0
fi
if [[ ! -f "$snapshot_path" ]]; then
  printf '{\n  "command": "bill-prediction-scan-scheduled",\n  "status": "skipped",\n  "reason": "snapshot file is missing",\n  "snapshotPath": "%s"\n}\n' "$snapshot_path"
  exit 0
fi
run_bill_cli prediction-scan "$snapshot_path"
