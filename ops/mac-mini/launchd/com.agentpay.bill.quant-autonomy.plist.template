<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.agentpay.bill.quant-autonomy</string>
    <key>ProgramArguments</key>
    <array>
      <string>__BILL_ROOT__/ops/mac-mini/bin/bill-quant-autonomy</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__BILL_ROOT__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>14400</integer>
    <key>StandardOutPath</key>
    <string>__BILL_ROOT__/.rumbling-hedge/logs/launchd-quant-autonomy.log</string>
    <key>StandardErrorPath</key>
    <string>__BILL_ROOT__/.rumbling-hedge/logs/launchd-quant-autonomy.err.log</string>
  </dict>
</plist>
