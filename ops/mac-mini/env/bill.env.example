# Preferred secure path on this Mac mini:
#   ~/Library/Application Support/AgentPay/bill/bill.env
#
# The Bill wrappers source that file automatically when present.
# Keep permissions at 600 and do not commit it.

RH_MODE=paper
RH_ACCOUNT_PHASE=challenge
RH_ENABLED_STRATEGIES=opening-range-reversal,session-momentum,liquidity-reversion,ict-displacement
# Mac Mini hosted-budget-first profile:
# - Use hosted free or cheap models for routine orchestration, coding, and review.
# - Keep local Ollama models installed only for degraded mode and background jobs.
export BILL_LOCAL_LIGHT_MODEL=ollama/qwen2.5-coder:7b
export BILL_LOCAL_HEAVY_MODEL=ollama/qwen2.5-coder:14b
export BILL_OLLAMA_MODEL=qwen2.5-coder:14b
export BILL_OLLAMA_EMBED_MODEL=nomic-embed-text
