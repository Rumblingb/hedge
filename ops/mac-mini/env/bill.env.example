# Preferred secure path on this Mac mini:
#   ~/Library/Application Support/AgentPay/bill/bill.env
#
# The Bill wrappers source that file automatically when present.
# Keep permissions at 600 and do not commit it.

RH_MODE=paper
RH_ACCOUNT_PHASE=challenge
export BILL_LOCAL_LIGHT_MODEL=ollama/qwen2.5-coder:7b
export BILL_LOCAL_HEAVY_MODEL=ollama/qwen2.5-coder:14b
export BILL_CLOUD_REVIEW_MODEL=openai/gpt-5.4-mini
export BILL_CLOUD_DEEP_REVIEW_MODEL=openai/gpt-5.4
export BILL_MAX_HEAVY_JOBS=1
export BILL_MAX_CLOUD_REVIEWS_PER_DAY=3
export BILL_MARKET_PRIORITY_ONLY=true
export BILL_SCHEDULED_LLM_LOOP=weekly
export BILL_ENABLE_PAPER_LOOP=false
export BILL_ENABLE_PREDICTION_COLLECT=false
export BILL_ENABLE_PREDICTION_SCAN=false
export BILL_ENABLE_PREDICTION_REPORT=true
export BILL_ENABLE_RESEARCH_COLLECT=false
export BILL_TIMEZONE=Asia/Kolkata
export BILL_PREDICTION_SOURCE=combined
export BILL_PREDICTION_SOURCES=polymarket,kalshi,manifold
export BILL_PREDICTION_REQUIRED_SOURCES=polymarket,kalshi
export BILL_PREDICTION_COLLECT_LIMIT=25
BILL_PREDICTION_COLLECT_OUTPUT_PATH=data/prediction/combined-live-snapshot.json
BILL_PREDICTION_SNAPSHOT_PATH=
BILL_PREDICTION_JOURNAL_PATH=journals/prediction-opportunities.jsonl
export BILL_PREDICTION_MIN_HEALTHY_VENUES=2
export BILL_PREDICTION_MIN_ROWS_PER_VENUE=5
export BILL_PREDICTION_MIN_WATCH_CANDIDATES=1
export BILL_PREDICTION_MIN_PAPER_CANDIDATES=1
export BILL_PREDICTION_KALSHI_SERIES_ALLOWLIST=
BILL_PREDICTION_BANKROLL=100
export BILL_PREDICTION_BANKROLL_CURRENCY=GBP
BILL_PREDICTION_MAX_RISK_PCT=0.01
BILL_PREDICTION_MAX_EXPOSURE_PCT=0.05
BILL_PREDICTION_MIN_STAKE=1
BILL_PREDICTION_CONFIDENCE_HAIRCUT=0.5
BILL_PREDICTION_LIQUIDITY_CAP_PCT=0.02
BILL_PREDICTION_CYCLE_HISTORY_PATH=.rumbling-hedge/logs/prediction-cycle-history.jsonl
BILL_PREDICTION_CYCLE_LOCK_DIR=.rumbling-hedge/run/prediction-cycle.lock
export BILL_PREDICTION_REVIEW_PATH=.rumbling-hedge/state/prediction-review.latest.json
export BILL_PROMOTION_STATE_PATH=.rumbling-hedge/state/promotion-state.json
export BILL_RESEARCH_CATALOG_PATH=.rumbling-hedge/research/catalog.json
export BILL_WORKSPACE_MEMORY_DIR=/Users/baskar_viji/.openclaw/workspace-bill/memory
RH_ALLOWED_SYMBOLS=NQ,ES
RH_JOURNAL_PATH=.rumbling-hedge/journal.jsonl
RH_KILL_SWITCH_PATH=.rumbling-hedge/kill-switch.json
RH_LIVE_EXECUTION_ENABLED=false
# Current repo config uses RH_TOPSTEP_* names for both Topstep and ProjectX-style adapter wiring.
RH_TOPSTEP_DEMO_ONLY=true
RH_TOPSTEP_READ_ONLY=true
RH_TOPSTEP_BASE_URL=
RH_TOPSTEP_USERNAME=
RH_TOPSTEP_ACCOUNT_ID=
RH_TOPSTEP_ALLOWED_ACCOUNT_ID=
RH_TOPSTEP_ALLOWED_ACCOUNT_LABEL="Demo Test"
RH_TOPSTEP_API_KEY=
RH_POLYGON_ENABLED=false
RH_POLYGON_API_KEY=
RH_POLYGON_BASE_URL=https://api.polygon.io
